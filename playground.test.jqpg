# ============================================================
# JQ Playground — Test completo di tutte le funzionalità
# ============================================================
# Questo file verifica ogni feature dell'estensione:
# - Variabili editor (VAR=value)
# - Input inline JSON
# - Input da file locale
# - Input da URL remoto
# - Input da shell command ($ ...)
# - Input da workspace document (nome file aperto)
# - Output a console (default)
# - Output a editor (via CodeLens shift+enter)
# - Output redirect a file (> path)
# - Output redirect append (>> path)
# - Filtri single-line
# - Filtri multiline (tra apici singoli)
# - Opzioni jq (--arg, --slurp, --raw-output, ecc.)
# - Edge case: JSON vuoto, null, array vuoti, unicode, ecc.
# ============================================================
TOKEN = 1234
ENDPOINT = bearer

# ----------------------------------------------------------
# 1. FILTRO BASE — identity con inline JSON
# ----------------------------------------------------------
jq '.'
{"name": "test", "value": 42}

# ----------------------------------------------------------
# 2. FILTRO SENZA APICI — identity
# ----------------------------------------------------------
jq .
{"simple": true}

# ----------------------------------------------------------
# 3. ACCESSO A CAMPO
# ----------------------------------------------------------
jq '.name'
{"name": "Alice", "age": 30}

# ----------------------------------------------------------
# 4. ACCESSO A CAMPO NESTED
# ----------------------------------------------------------
jq '.a.b.c'
{"a": {"b": {"c": "deep"}}}

# ----------------------------------------------------------
# 5. ACCESSO CON BRACKET NOTATION
# ----------------------------------------------------------
jq '.["special-key"]'
{"special-key": "works"}

# ----------------------------------------------------------
# 6. ACCESSO AD ARRAY PER INDICE
# ----------------------------------------------------------
jq '.[0]'
[{"first": true}, {"second": true}]

# ----------------------------------------------------------
# 7. INDICE NEGATIVO
# ----------------------------------------------------------
jq '.[-1]'
[1, 2, 3, 4, 5]

# ----------------------------------------------------------
# 8. ARRAY SLICE
# ----------------------------------------------------------
jq '.[2:4]'
["a", "b", "c", "d", "e"]

# ----------------------------------------------------------
# 9. ARRAY SLICE — solo inizio
# ----------------------------------------------------------
jq '.[-2:]'
[10, 20, 30, 40, 50]

# ----------------------------------------------------------
# 10. ARRAY SLICE — solo fine
# ----------------------------------------------------------
jq '.[:3]'
[10, 20, 30, 40, 50]

# ----------------------------------------------------------
# 11. ITERAZIONE ARRAY
# ----------------------------------------------------------
jq '.[]'
[1, 2, 3]

# ----------------------------------------------------------
# 12. ITERAZIONE OGGETTO
# ----------------------------------------------------------
jq '.[]'
{"a": 1, "b": 2, "c": 3}

# ----------------------------------------------------------
# 13. PIPE — concatenazione filtri
# ----------------------------------------------------------
jq '.[] | .name'
[{"name": "JSON"}, {"name": "XML"}]

# ----------------------------------------------------------
# 14. VIRGOLA — output multipli
# ----------------------------------------------------------
jq '.foo, .bar'
{"foo": 42, "bar": "hello"}

# ----------------------------------------------------------
# 15. COSTRUZIONE ARRAY
# ----------------------------------------------------------
jq '[.[] | . * 2]'
[1, 2, 3]

# ----------------------------------------------------------
# 16. COSTRUZIONE OGGETTO
# ----------------------------------------------------------
jq '{user, title: .titles[]}'
{"user": "alice", "titles": ["Dev", "Lead"]}

# ----------------------------------------------------------
# 17. CHIAVE DINAMICA
# ----------------------------------------------------------
jq '{(.key): .value}'
{"key": "name", "value": "Bob"}

# ----------------------------------------------------------
# 18. ARITMETICA
# ----------------------------------------------------------
jq '.a + .b * 2'
{"a": 10, "b": 5}

# ----------------------------------------------------------
# 19. CONCATENAZIONE STRINGHE
# ----------------------------------------------------------
jq '.first + " " + .last'
{"first": "John", "last": "Doe"}

# ----------------------------------------------------------
# 20. CONCATENAZIONE ARRAY
# ----------------------------------------------------------
jq '.a + .b'
{"a": [1, 2], "b": [3, 4]}

# ----------------------------------------------------------
# 21. DIVISIONE STRINGA
# ----------------------------------------------------------
jq '. / ", "'
"a, b, c, d"

# ----------------------------------------------------------
# 22. SELECT — filtro condizionale
# ----------------------------------------------------------
jq '[.[] | select(. > 3)]'
[1, 5, 2, 7, 3, 8]

# ----------------------------------------------------------
# 23. SELECT SU OGGETTI
# ----------------------------------------------------------
jq '.[] | select(.active == true) | .name'
[{"name": "a", "active": true}, {"name": "b", "active": false}, {"name": "c", "active": true}]

# ----------------------------------------------------------
# 24. MAP
# ----------------------------------------------------------
jq 'map(. + 10)'
[1, 2, 3]

# ----------------------------------------------------------
# 25. MAP_VALUES
# ----------------------------------------------------------
jq 'map_values(. * 2)'
{"x": 1, "y": 2, "z": 3}

# ----------------------------------------------------------
# 26. KEYS
# ----------------------------------------------------------
jq 'keys'
{"z": 1, "a": 2, "m": 3}

# ----------------------------------------------------------
# 27. VALUES
# ----------------------------------------------------------
jq '[keys[], values[]]'
{"a": 1, "b": 2}

# ----------------------------------------------------------
# 28. HAS
# ----------------------------------------------------------
jq 'map(has("foo"))'
[{"foo": 1}, {"bar": 2}, {"foo": 3}]

# ----------------------------------------------------------
# 29. LENGTH
# ----------------------------------------------------------
jq '[.[] | length]'
["hello", [1,2,3], {"a":1}, null]

# ----------------------------------------------------------
# 30. TYPE
# ----------------------------------------------------------
jq 'map(type)'
[1, "two", true, null, [3], {"four": 4}]

# ----------------------------------------------------------
# 31. SORT
# ----------------------------------------------------------
jq 'sort'
[3, 1, 4, 1, 5, 9, 2, 6]

# ----------------------------------------------------------
# 32. SORT_BY
# ----------------------------------------------------------
jq 'sort_by(.age)'
[{"name": "c", "age": 30}, {"name": "a", "age": 10}, {"name": "b", "age": 20}]

# ----------------------------------------------------------
# 33. GROUP_BY
# ----------------------------------------------------------
jq 'group_by(.type)'
[{"type": "a", "v": 1}, {"type": "b", "v": 2}, {"type": "a", "v": 3}]

# ----------------------------------------------------------
# 34. UNIQUE
# ----------------------------------------------------------
jq 'unique'
[1, 2, 1, 3, 2, 4]

# ----------------------------------------------------------
# 35. FLATTEN
# ----------------------------------------------------------
jq 'flatten'
[1, [2, [3, [4]]]]

# ----------------------------------------------------------
# 36. FLATTEN CON PROFONDITÀ
# ----------------------------------------------------------
jq 'flatten(1)'
[1, [2, [3, [4]]]]

# ----------------------------------------------------------
# 37. REVERSE
# ----------------------------------------------------------
jq 'reverse'
[1, 2, 3, 4, 5]

# ----------------------------------------------------------
# 38. ADD
# ----------------------------------------------------------
jq 'add'
[1, 2, 3, 4]

# ----------------------------------------------------------
# 39. ANY / ALL
# ----------------------------------------------------------
jq '[any, all]'
[true, false, true]

# ----------------------------------------------------------
# 40. RANGE
# ----------------------------------------------------------
jq '[range(5)]'
null

# ----------------------------------------------------------
# 41. RANGE CON STEP
# ----------------------------------------------------------
jq '[range(0; 20; 3)]'
null

# ----------------------------------------------------------
# 42. REDUCE
# ----------------------------------------------------------
jq 'reduce .[] as $x (0; . + $x)'
[10, 20, 30]

# ----------------------------------------------------------
# 43. FOREACH
# ----------------------------------------------------------
jq '[foreach .[] as $x (0; . + $x)]'
[1, 2, 3, 4, 5]

# ----------------------------------------------------------
# 44. TO_ENTRIES / FROM_ENTRIES
# ----------------------------------------------------------
jq 'to_entries'
{"a": 1, "b": 2}

# ----------------------------------------------------------
# 45. WITH_ENTRIES
# ----------------------------------------------------------
jq 'with_entries(.key |= "prefix_" + .)'
{"x": 1, "y": 2}

# ----------------------------------------------------------
# 46. DEL
# ----------------------------------------------------------
jq 'del(.foo)'
{"foo": 1, "bar": 2, "baz": 3}

# ----------------------------------------------------------
# 47. GETPATH / SETPATH
# ----------------------------------------------------------
jq 'getpath(["a", "b"])'
{"a": {"b": 42}}

# ----------------------------------------------------------
# 48. CONTAINS
# ----------------------------------------------------------
jq 'contains({"a": 1})'
{"a": 1, "b": 2}

# ----------------------------------------------------------
# 49. INSIDE
# ----------------------------------------------------------
jq 'inside(["foo", "bar", "foobar"])'
["foo", "bar"]

# ----------------------------------------------------------
# 50. TEST — regex
# ----------------------------------------------------------
jq 'test("^[0-9]+$")'
"12345"

# ----------------------------------------------------------
# 51. MATCH — regex
# ----------------------------------------------------------
jq 'match("(?<digits>[0-9]+)")'
"abc123def"

# ----------------------------------------------------------
# 52. CAPTURE — regex
# ----------------------------------------------------------
jq 'capture("(?<name>[a-z]+)-(?<num>[0-9]+)")'
"hello-42"

# ----------------------------------------------------------
# 53. SPLIT — regex
# ----------------------------------------------------------
jq '[spli(",\\s*"; null)]'
"a, b,  c,d"

# ----------------------------------------------------------
# 54. SUB / GSUB
# ----------------------------------------------------------
jq 'gsub("(?<x>[aeiou])"; "[\(.x)]")'
"hello world"

# ----------------------------------------------------------
# 55. STRING INTERPOLATION
# ----------------------------------------------------------
jq '"Name: \(.name), Age: \(.age)"'
{"name": "Alice", "age": 30}

# ----------------------------------------------------------
# 56. TOSTRING / TONUMBER
# ----------------------------------------------------------
jq '[.[] | tostring]'
[1, "two", true, null]

# ----------------------------------------------------------
# 57. @BASE64 / @BASE64D
# ----------------------------------------------------------
jq '@base64'
"Hello, World!"

# ----------------------------------------------------------
# 58. @HTML
# ----------------------------------------------------------
jq '@html'
"<script>alert('xss')</script>"

# ----------------------------------------------------------
# 59. @URI
# ----------------------------------------------------------
jq '@uri'
"hello world/foo"

# ----------------------------------------------------------
# 60. @CSV / @TSV
# ----------------------------------------------------------
jq '[.[] | [.name, .age]] | .[] | @csv'
[{"name": "Alice", "age": 30}, {"name": "Bob", "age": 25}]

# ----------------------------------------------------------
# 61. IF/THEN/ELSE
# ----------------------------------------------------------
jq 'if . > 0 then "positive" elif . == 0 then "zero" else "negative" end'
-5

# ----------------------------------------------------------
# 62. TRY/CATCH
# ----------------------------------------------------------
jq 'try error("boom") catch .'
null

# ----------------------------------------------------------
# 63. OPTIONAL OPERATOR (?)
# ----------------------------------------------------------
jq '[.[] | .foo?]'
[{"foo": 1}, "not_object", {"foo": 3}]

# ----------------------------------------------------------
# 64. ALTERNATIVE OPERATOR (//)
# ----------------------------------------------------------
jq '.foo // "default"'
{"bar": 1}

# ----------------------------------------------------------
# 65. RECURSIVE DESCENT (..)
# ----------------------------------------------------------
jq '[.. | numbers]'
{"a": 1, "b": {"c": 2, "d": [3, 4]}}

# ----------------------------------------------------------
# 66. PATH
# ----------------------------------------------------------
jq '[path(..)]'
{"a": [1]}

# ----------------------------------------------------------
# 67. WALK
# ----------------------------------------------------------
jq 'walk(if type == "number" then . * 2 else . end)'
{"a": 1, "b": [2, 3]}

# ----------------------------------------------------------
# 68. ENV — variabili d'ambiente
# ----------------------------------------------------------
jq 'env.HOME'
null

# ----------------------------------------------------------
# 69. LABEL/BREAK
# ----------------------------------------------------------
jq 'label $out | foreach .[] as $x (0; . + $x; if . > 5 then ., break $out else . end)'
[1, 2, 3, 4, 5]

# ----------------------------------------------------------
# 70. LIMIT
# ----------------------------------------------------------
jq '[limit(3; .[])]'
[1, 2, 3, 4, 5, 6, 7, 8, 9]

# ----------------------------------------------------------
# 71. FIRST / LAST
# ----------------------------------------------------------
jq '[first(.[] | select(. > 3)), last(.[] | select(. > 3))]'
[1, 5, 2, 7, 3, 8]

# ----------------------------------------------------------
# 72. ISEMPTY
# ----------------------------------------------------------
jq '[isempty(empty), isempty(.[])]'
[1, 2]

# ----------------------------------------------------------
# 73. INDICES / INDEX / RINDEX
# ----------------------------------------------------------
jq 'indices(", ")'
"a, b, c, d"

# ----------------------------------------------------------
# 74. STARTSWITH / ENDSWITH
# ----------------------------------------------------------
jq '[.[] | select(startswith("foo"))]'
["foobar", "barfoo", "foobaz", "baz"]

# ----------------------------------------------------------
# 75. LTRIMSTR / RTRIMSTR
# ----------------------------------------------------------
jq '.[] | ltrimstr("hello_")'
["hello_world", "goodbye_world", "hello_there"]

# ----------------------------------------------------------
# 76. EXPLODE / IMPLODE
# ----------------------------------------------------------
jq '[explode[] + 1] | implode'
"HAL"

# ----------------------------------------------------------
# 77. ASCII_UPCASE / ASCII_DOWNCASE
# ----------------------------------------------------------
jq '{up: ascii_upcase, down: ascii_downcase}'
"Hello World"

# ----------------------------------------------------------
# 78. TOJSON / FROMJSON
# ----------------------------------------------------------
jq 'tojson | fromjson'
{"a": [1, 2, 3]}

# ----------------------------------------------------------
# 79. DATES
# ----------------------------------------------------------
jq 'todate'
1425599507

# ----------------------------------------------------------
# 80. UPDATE ASSIGNMENT (|=)
# ----------------------------------------------------------
jq '.foo |= . + 10'
{"foo": 32, "bar": 1}

# ----------------------------------------------------------
# 81. ALTERNATIVE UPDATE (?//=)
# ----------------------------------------------------------
jq '.foo //= "default"'
{"bar": 1}

# ----------------------------------------------------------
# 82. ADD ASSIGNMENT (+=)
# ----------------------------------------------------------
jq '.items += ["new"]'
{"items": ["old"]}

# ----------------------------------------------------------
# 83. COMPLEX UPDATE — nested
# ----------------------------------------------------------
jq '(.users[] | select(.active) | .score) += 10'
{"users": [{"name": "a", "active": true, "score": 5}, {"name": "b", "active": false, "score": 3}]}


# ==========================================================
# OPZIONI JQ
# ==========================================================

# ----------------------------------------------------------
# 84. --raw-output (-r)
# ----------------------------------------------------------
jq -r '.name'
{"name": "Alice"}

# ----------------------------------------------------------
# 85. --compact-output (-c)
# ----------------------------------------------------------
jq -c '.'
{"a": 1, "b": 2, "c": 3}

# ----------------------------------------------------------
# 86. --sort-keys (-S)
# ----------------------------------------------------------
jq -S '.'
{"z": 1, "a": 2, "m": 3}

# ----------------------------------------------------------
# 87. --slurp (-s)
# ----------------------------------------------------------
jq -s '.'
[1, 2, 3]

# ----------------------------------------------------------
# 88. --null-input (-n)
# ----------------------------------------------------------
jq -n '{"generated": true, "timestamp": now}'
null

# ----------------------------------------------------------
# 89. --arg
# ----------------------------------------------------------
jq --arg name "World" '"Hello, \($name)!"'
null

# ----------------------------------------------------------
# 90. --argjson
# ----------------------------------------------------------
jq --argjson count 42 '{count: $count, type: ($count | type)}'
null

# ----------------------------------------------------------
# 91. --tab
# ----------------------------------------------------------
jq --tab '.'
{"indented": true}

# ----------------------------------------------------------
# 92. --indent
# ----------------------------------------------------------
jq --indent 4 '.'
{"wide": "indent"}

# ----------------------------------------------------------
# 93. --join-output (-j) — no newline
# ----------------------------------------------------------
jq -j '.a, .b'
{"a": "hello", "b": "world"}

# ----------------------------------------------------------
# 94. OPZIONI COMBINATE
# ----------------------------------------------------------
jq -r -S '.[] | keys[]'
[{"z": 1, "a": 2}, {"m": 3, "b": 4}]


# ==========================================================
# FILTRI MULTILINE
# ==========================================================

# ----------------------------------------------------------
# 95. MULTILINE — filtro su più righe
# ----------------------------------------------------------
jq '
  .[] |
  select(.age > 20) |
  {name, age}
'
[{"name": "Alice", "age": 30}, {"name": "Bob", "age": 15}, {"name": "Carol", "age": 25}]

# ----------------------------------------------------------
# 96. MULTILINE — if/then/else
# ----------------------------------------------------------
jq '
  if .value > 100 then
    "high"
  elif .value > 50 then
    "medium"
  else
    "low"
  end
'
{"value": 75}

# ----------------------------------------------------------
# 97. MULTILINE — def con ricorsione
# ----------------------------------------------------------
jq '
  def factorial:
    if . <= 1 then 1
    else . * ((. - 1) | factorial)
    end;
  factorial
'
5

# ----------------------------------------------------------
# 98. MULTILINE — reduce complesso
# ----------------------------------------------------------
jq '
  reduce .[] as {$name, $score} (
    {};
    .[$name] += $score
  )
'
[{"name": "a", "score": 10}, {"name": "b", "score": 20}, {"name": "a", "score": 5}]


# ==========================================================
# VARIABILI EDITOR
# ==========================================================

# ----------------------------------------------------------
# 99. VARIABILI — sostituzione in shell command
# ----------------------------------------------------------
jq '.'
$ curl -X GET "http://httpbin.org/$ENDPOINT" -H "accept: application/json" -H "Authorization: Bearer $TOKEN"

# ----------------------------------------------------------
# 100. VARIABILI — con --arg
# ----------------------------------------------------------
jq --arg msg "from_editor" '{"message": $msg}'
null


# ==========================================================
# INPUT DA SHELL COMMAND
# ==========================================================

# ----------------------------------------------------------
# 101. SHELL — echo semplice
# ----------------------------------------------------------
jq '.'
$ echo '{"from": "shell"}'

# ----------------------------------------------------------
# 102. SHELL — echo con argomenti quotati
# ----------------------------------------------------------
jq '.items | length'
$ echo '{"items": [1, 2, 3, 4, 5]}'

# ----------------------------------------------------------
# 103. SHELL — printf
# ----------------------------------------------------------
jq '.count'
$ printf '{"count": 42}'

# ----------------------------------------------------------
# 104. SHELL — cat di file (se esiste)
# ----------------------------------------------------------
# jq '.'
# $ cat /tmp/test-jqpg.json


# ==========================================================
# INPUT DA URL
# ==========================================================

# ----------------------------------------------------------
# 105. URL — API pubblica
# ----------------------------------------------------------
jq '.title'
https://jsonplaceholder.typicode.com/todos/1

# ----------------------------------------------------------
# 106. URL — con filtro complesso
# ----------------------------------------------------------
jq '{id, title, done: .completed}'
https://jsonplaceholder.typicode.com/todos/3

# ----------------------------------------------------------
# 107. URL — array remoto con select
# ----------------------------------------------------------
jq '[.[] | select(.userId == 1)] | length'
https://jsonplaceholder.typicode.com/todos


# ==========================================================
# OUTPUT REDIRECT
# ==========================================================

# ----------------------------------------------------------
# 108. REDIRECT — output a file (> path)
# ----------------------------------------------------------
jq '.'
> /tmp/jqpg-test-output.json
{"redirected": "to_file"}

# ----------------------------------------------------------
# 109. REDIRECT — append a file (>> path)
# ----------------------------------------------------------
jq '.'
>> /tmp/jqpg-test-output.json
{"appended": "to_file"}


# ==========================================================
# EDGE CASES
# ==========================================================

# ----------------------------------------------------------
# 110. EDGE — null input
# ----------------------------------------------------------
jq '.'
null

# ----------------------------------------------------------
# 111. EDGE — empty object
# ----------------------------------------------------------
jq '.'
{}

# ----------------------------------------------------------
# 112. EDGE — empty array
# ----------------------------------------------------------
jq '.'
[]

# ----------------------------------------------------------
# 113. EDGE — empty string
# ----------------------------------------------------------
jq '.'
""

# ----------------------------------------------------------
# 114. EDGE — numero zero
# ----------------------------------------------------------
jq '. == 0'
0

# ----------------------------------------------------------
# 115. EDGE — boolean false
# ----------------------------------------------------------
jq 'not'
false

# ----------------------------------------------------------
# 116. EDGE — boolean true
# ----------------------------------------------------------
jq 'not'
true

# ----------------------------------------------------------
# 117. EDGE — numero molto grande
# ----------------------------------------------------------
jq '. + 1'
99999999999999999999999999

# ----------------------------------------------------------
# 118. EDGE — numero molto piccolo (float)
# ----------------------------------------------------------
jq '. * 2'
0.000000000000001

# ----------------------------------------------------------
# 119. EDGE — numero negativo
# ----------------------------------------------------------
jq 'fabs'
-42.5

# ----------------------------------------------------------
# 120. EDGE — stringa con escape
# ----------------------------------------------------------
jq '.'
"line1\nline2\ttab\"quoted\""

# ----------------------------------------------------------
# 121. EDGE — stringa con unicode
# ----------------------------------------------------------
jq 'length'
"こんにちは世界"

# ----------------------------------------------------------
# 122. EDGE — stringa con emoji
# ----------------------------------------------------------
jq '.'
"🎉🚀💻"

# ----------------------------------------------------------
# 123. EDGE — array annidato profondo
# ----------------------------------------------------------
jq 'flatten'
[1, [2, [3, [4, [5]]]]]

# ----------------------------------------------------------
# 124. EDGE — oggetto con chiavi speciali
# ----------------------------------------------------------
jq '.[""]'
{"": "empty_key", " ": "space_key", "a.b": "dotted"}

# ----------------------------------------------------------
# 125. EDGE — chiave con punto
# ----------------------------------------------------------
jq '.["a.b"]'
{"a.b": "dotted_key", "a": {"b": "nested"}}

# ----------------------------------------------------------
# 126. EDGE — array con tipi misti
# ----------------------------------------------------------
jq 'map(type)'
[1, "two", true, null, [], {}, 3.14]

# ----------------------------------------------------------
# 127. EDGE — oggetto con valori null
# ----------------------------------------------------------
jq 'map_values(. // "was_null")'
{"a": 1, "b": null, "c": "hello", "d": null}

# ----------------------------------------------------------
# 128. EDGE — JSON multiline inline
# ----------------------------------------------------------
jq '.users | map(.name)'
{
  "users": [
    {"name": "Alice", "age": 30},
    {"name": "Bob", "age": 25}
  ]
}

# ----------------------------------------------------------
# 129. EDGE — filtro identity minimo '.'
# ----------------------------------------------------------
jq '.'
42

# ----------------------------------------------------------
# 130. EDGE — filtro senza apici, identity
# ----------------------------------------------------------
jq .
"just a string"

# ----------------------------------------------------------
# 131. EDGE — empty produce nessun output
# ----------------------------------------------------------
jq 'empty'
"anything"

# ----------------------------------------------------------
# 132. EDGE — error con try
# ----------------------------------------------------------
jq '[.[] | try (1 / .)]'
[1, 0, 2, 0, 3]

# ----------------------------------------------------------
# 133. EDGE — null propagation
# ----------------------------------------------------------
jq '.a.b.c.d'
{}

# ----------------------------------------------------------
# 134. EDGE — input con whitespace significativo
# ----------------------------------------------------------
jq 'keys'
{"  spaces  ": 1, "\ttab": 2, "\nnewline": 3}

# ----------------------------------------------------------
# 135. EDGE — stringa JSON come input (double-encoded)
# ----------------------------------------------------------
jq 'fromjson | .name'
"{\"name\": \"decoded\"}"

# ----------------------------------------------------------
# 136. EDGE — array vuoto con operazioni
# ----------------------------------------------------------
jq '{sum: add, len: length, first: first, last: last}'
[]

# ----------------------------------------------------------
# 137. EDGE — oggetto singolo campo
# ----------------------------------------------------------
jq 'to_entries | .[0]'
{"only": "one"}

# ----------------------------------------------------------
# 138. EDGE — numero come stringa
# ----------------------------------------------------------
jq 'tonumber | . + 1'
"42"

# ----------------------------------------------------------
# 139. EDGE — ascii art / stringa lunga
# ----------------------------------------------------------
jq 'length'
"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# ----------------------------------------------------------
# 140. EDGE — path con indice e chiave
# ----------------------------------------------------------
jq 'getpath(["a", 0, "b"])'
{"a": [{"b": "found"}]}

# ----------------------------------------------------------
# 141. EDGE — multiple outputs con limit
# ----------------------------------------------------------
jq '[limit(2; repeat(.))]'
"x"

# ----------------------------------------------------------
# 142. EDGE — def locale
# ----------------------------------------------------------
jq 'def double: . * 2; def quad: double | double; quad'
3

# ----------------------------------------------------------
# 143. EDGE — label/break
# ----------------------------------------------------------
jq 'first(range(10) | select(. > 5))'
null

# ----------------------------------------------------------
# 144. EDGE — input numerico puro
# ----------------------------------------------------------
jq '. * . | sqrt'
7

# ----------------------------------------------------------
# 145. EDGE — stringa vuota
# ----------------------------------------------------------
jq 'if . == "" then "empty" else "not empty" end'
""
